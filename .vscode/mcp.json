{
  "servers": {
    "microsoft.docs.mcp": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "io.github.upstash/context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@upstash/context7-mcp@1.0.31"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
      },
      "gallery": "https://api.mcp.github.com",
      "version": "1.0.31"
    },
    "microsoft/playwright-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "gallery": "https://api.mcp.github.com",
      "version": "0.0.1-seed"
    },
    "microsoft/markitdown": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "markitdown-mcp@0.0.1a4"
      ],
      "gallery": "https://api.mcp.github.com",
      "version": "1.0.0"
    },
    "io.github.github/github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "gallery": "https://api.mcp.github.com",
      "version": "0.32.0"
    },
    "oraios/serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "serena@latest",
        "--context",
        "ide-assistant"
      ],
      "gallery": "https://api.mcp.github.com",
      "version": "1.0.0"
    },
    "debugmcp": {
      "autoApprove": [],
      "disabled": true,
      "timeout": 180,
      "type": "streamableHttp",
      "url": "http://localhost:3001/mcp"
    },
    "microsoft/azure-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@azure/mcp@latest",
        "server",
        "start"
      ]
    },
    "azure/bicep-mcp": {
      "type": "stdio",
      "command": "dnx",
      "args": [
        "Azure.Bicep.McpServer",
        "--yes"
      ]
    },
    "solune": {
      "type": "http",
      "url": "http://localhost:8000/api/v1/mcp",
      "headers": {
        "Authorization": "Bearer ${input:github_pat}"
      }
    }
  },
  "inputs": [
    {
      "id": "CONTEXT7_API_KEY",
      "type": "promptString",
      "description": "API key for authentication",
      "password": true
    },
    {
      "id": "github_pat",
      "type": "promptString",
      "description": "GitHub Personal Access Token for Solune MCP server",
      "password": true
    }
  ],
  "mcpServers": {
    "Azure": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@azure/mcp@latest",
        "server",
        "start"
      ],
      "tools": [
        "*"
      ]
    },
    "Bicep": {
      "type": "local",
      "command": "dnx",
      "args": [
        "Azure.Bicep.McpServer",
        "--yes"
      ],
      "tools": [
        "*"
      ]
    }
  }
}
