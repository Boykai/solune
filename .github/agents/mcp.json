{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "$COPILOT_MCP_CONTEXT7_API_KEY"
      },
      "tools": [
        "resolve-library-id",
        "get-library-docs"
      ]
    },
    "azure-mcp": {
      "type": "local",
      "command": "npx",
      "args": [
        "@azure/mcp@latest",
        "server",
        "start"
      ],
      "tools": [
        "*"
      ]
    },
    "bicep-mcp": {
      "type": "local",
      "command": "dnx",
      "args": [
        "Azure.Bicep.McpServer",
        "--yes"
      ],
      "tools": [
        "get_bicep_best_practices",
        "list_az_resource_types_for_provider",
        "get_az_resource_type_schema",
        "decompile_arm_template_file",
        "decompile_arm_parameters_file",
        "format_bicep_file",
        "get_bicep_file_diagnostics",
        "get_file_references",
        "get_deployment_snapshot",
        "list_avm_metadata"
      ]
    }
  }
}