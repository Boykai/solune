{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "$COPILOT_MCP_CONTEXT7_API_KEY"
      },
      "tools": [
        "resolve-library-id",
        "get-library-docs"
      ]
    },
    "azure-mcp": {
      "type": "local",
      "command": "npx",
      "args": [
        "@azure/mcp@latest",
        "server",
        "start"
      ],
      "tools": [
        "*"
      ]
    }
  }
}