{
  "include": ["tests"],
  "exclude": ["**/__pycache__", "htmlcov"],
  "pythonVersion": "3.13",
  "typeCheckingMode": "off",
  "reportInvalidTypeForm": "none",
  "reportUnnecessaryTypeIgnoreComment": "error",
  "stubPath": "src/typestubs",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": ["src"]
    }
  ]
}
