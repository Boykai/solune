{
  "include": ["tests"],
  "exclude": ["**/__pycache__", "htmlcov"],
  "pythonVersion": "3.13",
  "typeCheckingMode": "standard",
  "reportMissingTypeStubs": false,
  "reportMissingImports": "warning",
  "stubPath": "src/typestubs",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": ["src"]
    }
  ]
}
