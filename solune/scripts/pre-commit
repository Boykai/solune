#!/bin/bash
# Git pre-commit hook that auto-fixes and validates code before commit
# This mirrors the CI checks in .github/workflows/ci.yml
#
# Install by running: ./scripts/setup-hooks.sh
# Or manually: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

echo "🔍 Running pre-commit checks (with auto-fix)..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any check fails
FAILED=0

# Get the repo root
REPO_ROOT="$(git rev-parse --show-toplevel)"

# Check if we have staged Python files
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
# Check if we have staged frontend files
STAGED_FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^solune/frontend/.*\.(ts|tsx|js|jsx)$' || true)
# Check if we have staged files that affect architecture diagrams
STAGED_ARCH_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^solune/backend/src/|^solune/frontend/src/|docker-compose\.yml$|^solune/scripts/generate-diagrams\.sh$)' || true)

# ============================================
# Backend Checks (with auto-fix)
# ============================================
if [ -n "$STAGED_PY_FILES" ]; then
    echo ""
    echo "📦 Backend checks..."

    # Check if we're in a virtual environment or if backend venv exists
    if [ -d "$REPO_ROOT/solune/backend/.venv" ]; then
        RUFF="$REPO_ROOT/solune/backend/.venv/bin/ruff"
    else
        RUFF="ruff"
    fi

    # Auto-format with ruff format, then verify
    echo -n "  🎨 Ruff formatting... "
    $RUFF format "$REPO_ROOT/solune/backend/src" "$REPO_ROOT/solune/backend/tests" --quiet 2>/dev/null || true
    if $RUFF format --check "$REPO_ROOT/solune/backend/src" "$REPO_ROOT/solune/backend/tests" --quiet 2>/dev/null; then
        echo -e "${GREEN}✓ (auto-formatted)${NC}"
    else
        echo -e "${RED}✗ (auto-fix failed)${NC}"
        FAILED=1
    fi

    # Auto-fix with ruff, then verify
    echo -n "  🔧 Ruff linting... "
    $RUFF check "$REPO_ROOT/solune/backend/src" "$REPO_ROOT/solune/backend/tests" --fix --quiet 2>/dev/null || true
    if $RUFF check "$REPO_ROOT/solune/backend/src" "$REPO_ROOT/solune/backend/tests" --quiet 2>/dev/null; then
        echo -e "${GREEN}✓ (auto-fixed)${NC}"
    else
        echo -e "${RED}✗ (issues remain after auto-fix)${NC}"
        echo -e "${YELLOW}    Remaining issues:${NC}"
        $RUFF check "$REPO_ROOT/solune/backend/src" "$REPO_ROOT/solune/backend/tests" 2>&1 | head -10
        FAILED=1
    fi

    # Re-stage auto-fixed Python files
    for file in $STAGED_PY_FILES; do
        if [ -f "$REPO_ROOT/$file" ]; then
            git add "$REPO_ROOT/$file" 2>/dev/null || true
        fi
    done

    # Type check with pyright (no auto-fix available for type errors)
    echo -n "  🐍 Pyright type check... "
    if [ -d "$REPO_ROOT/solune/backend/.venv" ]; then
        PYRIGHT="$REPO_ROOT/solune/backend/.venv/bin/pyright"
    else
        PYRIGHT="pyright"
    fi

    PYRIGHT_PYTHON_ARGS=()
    if [ -d "$REPO_ROOT/solune/backend/.venv" ]; then
        PYRIGHT_PYTHON_ARGS=(--pythonpath "$REPO_ROOT/solune/backend/.venv/bin/python")
    fi

    if $PYRIGHT "$REPO_ROOT/solune/backend/src" "${PYRIGHT_PYTHON_ARGS[@]}" > /dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Type errors must be fixed manually${NC}"
        $PYRIGHT "$REPO_ROOT/solune/backend/src" "${PYRIGHT_PYTHON_ARGS[@]}" 2>&1 | tail -10
        FAILED=1
    fi

    echo -n "  🧪 Pyright tests... "
    if $PYRIGHT "$REPO_ROOT/solune/backend/tests" "${PYRIGHT_PYTHON_ARGS[@]}" > /dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Test type errors must be fixed manually${NC}"
        $PYRIGHT "$REPO_ROOT/solune/backend/tests" "${PYRIGHT_PYTHON_ARGS[@]}" 2>&1 | tail -10
        FAILED=1
    fi

    # Run backend tests (mirrors CI: pytest with coverage)
    echo -n "  🧪 Pytest... "
    if [ -d "$REPO_ROOT/solune/backend/.venv" ]; then
        PYTEST="$REPO_ROOT/solune/backend/.venv/bin/pytest"
    else
        PYTEST="pytest"
    fi

    if $PYTEST "$REPO_ROOT/solune/backend" --ignore=tests/property --ignore=tests/fuzz --ignore=tests/chaos --ignore=tests/concurrency -q --no-header --tb=no > /dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Test failures must be fixed manually${NC}"
        $PYTEST "$REPO_ROOT/solune/backend" --ignore=tests/property --ignore=tests/fuzz --ignore=tests/chaos --ignore=tests/concurrency -q --no-header --tb=line 2>&1 | tail -15
        FAILED=1
    fi
fi

# ============================================
# Frontend Checks (with auto-fix)
# ============================================
if [ -n "$STAGED_FRONTEND_FILES" ]; then
    echo ""
    echo "🌐 Frontend checks..."

    cd "$REPO_ROOT/solune/frontend"

    # Auto-fix with ESLint, then verify
    echo -n "  📝 ESLint... "
    npm run lint -- --fix --quiet 2>/dev/null || true
    if npm run lint --silent 2>/dev/null; then
        echo -e "${GREEN}✓ (auto-fixed)${NC}"
    else
        # Check if only warnings (exit code 0 means success even with warnings)
        if npm run lint 2>&1 | grep -q "error"; then
            echo -e "${RED}✗ (errors remain)${NC}"
            npm run lint 2>&1 | grep "error" | head -5
            FAILED=1
        else
            echo -e "${GREEN}✓ (warnings only)${NC}"
        fi
    fi

    # TypeScript type check (no auto-fix available for type errors)
    echo -n "  📘 TypeScript check... "
    if npm run type-check --silent 2>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    TypeScript errors must be fixed manually${NC}"
        npm run type-check 2>&1 | head -10
        FAILED=1
    fi

    echo -n "  🧪 TypeScript tests... "
    if npm run type-check:test --silent 2>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Test TypeScript errors must be fixed manually${NC}"
        npm run type-check:test 2>&1 | head -10
        FAILED=1
    fi

    # Run tests (mirrors CI: npm test)
    echo -n "  🧪 Vitest... "
    if npm test --silent 2>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Test failures must be fixed manually${NC}"
        npm test 2>&1 | tail -15
        FAILED=1
    fi

    # Build check (mirrors CI: npm run build)
    echo -n "  🏗️  Build... "
    if npm run build --silent 2>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Build errors must be fixed manually${NC}"
        npm run build 2>&1 | tail -10
        FAILED=1
    fi

    # Re-stage auto-fixed frontend files
    cd "$REPO_ROOT"
    for file in $STAGED_FRONTEND_FILES; do
        if [ -f "$REPO_ROOT/$file" ]; then
            git add "$REPO_ROOT/$file" 2>/dev/null || true
        fi
    done
fi

# ============================================
# Documentation Lint (mirrors CI: Docs Lint)
# ============================================
STAGED_DOC_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$' || true)

if [ -n "$STAGED_DOC_FILES" ]; then
    echo ""
    echo "📄 Documentation checks..."

    if command -v markdownlint > /dev/null 2>&1; then
        echo -n "  📝 Markdownlint... "
        if markdownlint "solune/docs/**/*.md" "*.md" --config solune/.markdownlint.json > /dev/null 2>&1; then
            echo -e "${GREEN}✓${NC}"
        else
            echo -e "${RED}✗${NC}"
            echo -e "${YELLOW}    Markdown lint errors:${NC}"
            markdownlint "solune/docs/**/*.md" "*.md" --config solune/.markdownlint.json 2>&1 | head -10
            FAILED=1
        fi
    else
        echo -e "  📝 Markdownlint... ${YELLOW}⊘ skipped (not installed)${NC}"
    fi
fi

# ============================================
# Contract Validation (mirrors CI: Contract Validation)
# ============================================
STAGED_CONTRACT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^solune/backend/src/(api|models)/|^solune/frontend/src/types/)' || true)

if [ -n "$STAGED_CONTRACT_FILES" ]; then
    echo ""
    echo "📋 Contract validation..."

    echo -n "  🔗 OpenAPI schema + type generation... "
    if bash "$REPO_ROOT/solune/scripts/validate-contracts.sh" > /dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
        # Stage regenerated openapi.json and types if they changed
        git add "$REPO_ROOT/solune/backend/openapi.json" 2>/dev/null || true
        git add "$REPO_ROOT/solune/frontend/src/types/openapi-generated.d.ts" 2>/dev/null || true
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Contract validation failed — run: bash solune/scripts/validate-contracts.sh${NC}"
        FAILED=1
    fi
fi

# ============================================
# Architecture Diagram Regeneration
# ============================================
if [ -n "$STAGED_ARCH_FILES" ]; then
    echo ""
    echo "📊 Architecture diagrams..."

    echo -n "  🔄 Regenerating diagrams... "
    diag_err=$(mktemp)
    if "$REPO_ROOT/solune/scripts/generate-diagrams.sh" > /dev/null 2>"$diag_err"; then
        echo -e "${GREEN}✓${NC}"
        # Stage any updated diagram files
        git add "$REPO_ROOT/solune/docs/architectures/" 2>/dev/null || true
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Diagram generation failed${NC}"
        cat "$diag_err" >&2
        FAILED=1
    fi
    rm -f "$diag_err"
fi

# ============================================
# Final Result
# ============================================
echo ""
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
    exit 0
else
    echo -e "${RED}❌ Some checks failed. Please fix the remaining issues manually.${NC}"
    exit 1
fi
