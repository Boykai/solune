#!/bin/bash
# Git pre-commit hook that auto-fixes and validates code before commit
# This mirrors the CI checks in .github/workflows/ci.yml
#
# Install by running: ./scripts/setup-hooks.sh
# Or manually: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

echo "🔍 Running pre-commit checks (with auto-fix)..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any check fails
FAILED=0

# Get the repo root
REPO_ROOT="$(git rev-parse --show-toplevel)"
BACKEND_DIR="$REPO_ROOT/solune/backend"

run_markdownlint() {
    if command -v markdownlint > /dev/null 2>&1; then
        markdownlint "$@"
        return
    fi

    if command -v npx > /dev/null 2>&1; then
        npx --yes markdownlint-cli@0.48.0 "$@"
        return
    fi

    return 127
}

run_markdown_link_check() {
    if command -v markdown-link-check > /dev/null 2>&1; then
        markdown-link-check "$@"
        return
    fi

    if command -v npx > /dev/null 2>&1; then
        npx --yes markdown-link-check@3.14.2 "$@"
        return
    fi

    return 127
}

# Check if we have staged Python files
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
# Run backend CI-parity checks for any staged backend change, not only Python sources.
STAGED_BACKEND_CHANGES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^solune/backend/' || true)
# Run frontend CI-parity checks for any staged frontend change, not only TS/JS sources.
STAGED_FRONTEND_CHANGES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^solune/frontend/' || true)
# Check if we have staged frontend files
STAGED_FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^solune/frontend/.*\.(ts|tsx|js|jsx)$' || true)
# Check if we have staged files that affect architecture diagrams
STAGED_ARCH_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^solune/backend/src/|^solune/frontend/src/|docker-compose\.yml$|^solune/scripts/generate-diagrams\.sh$)' || true)

# ============================================
# Backend Checks (with auto-fix)
# ============================================
if [ -n "$STAGED_BACKEND_CHANGES" ]; then
    echo ""
    echo "📦 Backend checks..."

    # Check if we're in a virtual environment or if backend venv exists
    if [ -d "$BACKEND_DIR/.venv" ]; then
        RUFF="$BACKEND_DIR/.venv/bin/ruff"
    else
        RUFF="ruff"
    fi

    # Auto-format with ruff format, then verify
    echo -n "  🎨 Ruff formatting... "
    $RUFF format "$BACKEND_DIR/src" "$BACKEND_DIR/tests" --quiet 2>/dev/null || true
    if $RUFF format --check "$BACKEND_DIR/src" "$BACKEND_DIR/tests" --quiet 2>/dev/null; then
        echo -e "${GREEN}✓ (auto-formatted)${NC}"
    else
        echo -e "${RED}✗ (auto-fix failed)${NC}"
        FAILED=1
    fi

    # Auto-fix with ruff, then verify
    echo -n "  🔧 Ruff linting... "
    $RUFF check "$BACKEND_DIR/src" "$BACKEND_DIR/tests" --fix --quiet 2>/dev/null || true
    if $RUFF check "$BACKEND_DIR/src" "$BACKEND_DIR/tests" --quiet 2>/dev/null; then
        echo -e "${GREEN}✓ (auto-fixed)${NC}"
    else
        echo -e "${RED}✗ (issues remain after auto-fix)${NC}"
        echo -e "${YELLOW}    Remaining issues:${NC}"
        $RUFF check "$BACKEND_DIR/src" "$BACKEND_DIR/tests" 2>&1 | head -10
        FAILED=1
    fi

    # Re-stage auto-fixed Python files
    for file in $STAGED_PY_FILES; do
        if [ -f "$REPO_ROOT/$file" ]; then
            git add "$REPO_ROOT/$file" 2>/dev/null || true
        fi
    done

    # Type check with pyright (no auto-fix available for type errors)
    echo -n "  🐍 Pyright type check... "
    if [ -d "$BACKEND_DIR/.venv" ]; then
        PYRIGHT="$BACKEND_DIR/.venv/bin/pyright"
    else
        PYRIGHT="pyright"
    fi

    PYRIGHT_PYTHON_ARGS=()
    if [ -d "$BACKEND_DIR/.venv" ]; then
        PYRIGHT_PYTHON_ARGS=(--pythonpath "$BACKEND_DIR/.venv/bin/python")
    fi

    if $PYRIGHT "$BACKEND_DIR/src" "${PYRIGHT_PYTHON_ARGS[@]}" > /dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Type errors must be fixed manually${NC}"
        $PYRIGHT "$BACKEND_DIR/src" "${PYRIGHT_PYTHON_ARGS[@]}" 2>&1 | tail -10
        FAILED=1
    fi

    echo -n "  🧪 Pyright tests... "
    if $PYRIGHT -p "$BACKEND_DIR/pyrightconfig.tests.json" "${PYRIGHT_PYTHON_ARGS[@]}" > /dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Test type errors must be fixed manually${NC}"
        $PYRIGHT -p "$BACKEND_DIR/pyrightconfig.tests.json" "${PYRIGHT_PYTHON_ARGS[@]}" 2>&1 | tail -10
        FAILED=1
    fi

    echo -n "  🔒 Bandit security scan... "
    if [ -x "$BACKEND_DIR/.venv/bin/bandit" ]; then
        BANDIT_CMD=("$BACKEND_DIR/.venv/bin/bandit")
    elif command -v uv > /dev/null 2>&1; then
        BANDIT_CMD=(uv run --directory "$BACKEND_DIR" bandit)
    elif command -v bandit > /dev/null 2>&1; then
        BANDIT_CMD=(bandit)
    else
        BANDIT_CMD=()
    fi

    if [ ${#BANDIT_CMD[@]} -eq 0 ]; then
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Bandit is required to mirror the CI backend lint gates. Install backend dev dependencies first.${NC}"
        FAILED=1
    elif "${BANDIT_CMD[@]}" -r "$BACKEND_DIR/src" -ll -ii --skip B104,B608 > /dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Security issues must be fixed manually${NC}"
        "${BANDIT_CMD[@]}" -r "$BACKEND_DIR/src" -ll -ii --skip B104,B608 2>&1 | tail -10
        FAILED=1
    fi

    # Run backend tests (mirrors CI: pytest with coverage)
    echo -n "  🧪 Pytest... "
    if [ -d "$BACKEND_DIR/.venv" ]; then
        PYTEST="$BACKEND_DIR/.venv/bin/pytest"
    else
        PYTEST="pytest"
    fi

    BACKEND_PYTEST_ARGS=(
        tests
        --ignore=tests/property
        --ignore=tests/fuzz
        --ignore=tests/chaos
        --ignore=tests/concurrency
        -q
        --no-header
        --tb=no
    )

    if (
        cd "$BACKEND_DIR"
        $PYTEST "${BACKEND_PYTEST_ARGS[@]}"
    ) > /dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Test failures must be fixed manually${NC}"
        (
            cd "$BACKEND_DIR"
            $PYTEST tests --ignore=tests/property --ignore=tests/fuzz --ignore=tests/chaos --ignore=tests/concurrency -q --no-header --tb=line
        ) 2>&1 | tail -15
        FAILED=1
    fi
fi

# ============================================
# Frontend Checks (with auto-fix)
# ============================================
if [ -n "$STAGED_FRONTEND_CHANGES" ]; then
    echo ""
    echo "🌐 Frontend checks..."

    cd "$REPO_ROOT/solune/frontend"

    # Auto-fix with ESLint, then verify
    echo -n "  📝 ESLint... "
    npm run lint -- --fix --quiet 2>/dev/null || true
    if npm run lint --silent 2>/dev/null; then
        echo -e "${GREEN}✓ (auto-fixed)${NC}"
    else
        # Check if only warnings (exit code 0 means success even with warnings)
        if npm run lint 2>&1 | grep -q "error"; then
            echo -e "${RED}✗ (errors remain)${NC}"
            npm run lint 2>&1 | grep "error" | head -5
            FAILED=1
        else
            echo -e "${GREEN}✓ (warnings only)${NC}"
        fi
    fi

    # TypeScript type check (no auto-fix available for type errors)
    echo -n "  📘 TypeScript check... "
    if npm run type-check --silent 2>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    TypeScript errors must be fixed manually${NC}"
        npm run type-check 2>&1 | head -10
        FAILED=1
    fi

    echo -n "  🧪 TypeScript tests... "
    if npm run type-check:test --silent 2>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Test TypeScript errors must be fixed manually${NC}"
        npm run type-check:test 2>&1 | head -10
        FAILED=1
    fi

    # Run tests (mirrors CI: npm test)
    echo -n "  🧪 Vitest... "
    if npm test --silent 2>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Test failures must be fixed manually${NC}"
        npm test 2>&1 | tail -15
        FAILED=1
    fi

    # Build check (mirrors CI: npm run build)
    echo -n "  🏗️  Build... "
    if npm run build --silent 2>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Build errors must be fixed manually${NC}"
        npm run build 2>&1 | tail -10
        FAILED=1
    fi

    # Re-stage auto-fixed frontend files
    cd "$REPO_ROOT"
    for file in $STAGED_FRONTEND_FILES; do
        if [ -f "$REPO_ROOT/$file" ]; then
            git add "$REPO_ROOT/$file" 2>/dev/null || true
        fi
    done
fi

# ============================================
# Documentation Lint (mirrors CI: Docs Lint)
# ============================================
STAGED_DOC_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$' || true)

if [ -n "$STAGED_DOC_FILES" ]; then
    echo ""
    echo "📄 Documentation checks..."

    echo -n "  📝 Markdownlint... "
    if run_markdownlint "solune/docs/**/*.md" "*.md" --config solune/.markdownlint.json > /dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
    else
        markdownlint_status=$?
        echo -e "${RED}✗${NC}"
        if [ $markdownlint_status -eq 127 ]; then
            echo -e "${YELLOW}    markdownlint is required to mirror the CI docs lint gate. Install Node.js/npm first.${NC}"
        else
            echo -e "${YELLOW}    Markdown lint errors:${NC}"
            run_markdownlint "solune/docs/**/*.md" "*.md" --config solune/.markdownlint.json 2>&1 | head -10
        fi
        FAILED=1
    fi

    echo -n "  🔗 Markdown links... "
    if ! command -v npx > /dev/null 2>&1 && ! command -v markdown-link-check > /dev/null 2>&1; then
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    markdown-link-check is required to mirror the CI docs link gate. Install Node.js/npm first.${NC}"
        FAILED=1
    else
        doc_link_failed=0
        while IFS= read -r -d '' doc_file; do
            if ! run_markdown_link_check "$doc_file" --config solune/.markdown-link-check.json --quiet > /dev/null 2>&1; then
                doc_link_failed=1
                break
            fi
        done < <(find solune/docs -name "*.md" -print0)

        if [ $doc_link_failed -eq 0 ] && ! run_markdown_link_check README.md --config solune/.markdown-link-check.json --quiet > /dev/null 2>&1; then
            doc_link_failed=1
        fi

        if [ $doc_link_failed -eq 0 ]; then
            echo -e "${GREEN}✓${NC}"
        else
            echo -e "${RED}✗${NC}"
            echo -e "${YELLOW}    Documentation link errors:${NC}"
            find solune/docs -name "*.md" -print0 | while IFS= read -r -d '' doc_file; do
                run_markdown_link_check "$doc_file" --config solune/.markdown-link-check.json --quiet && continue
                break
            done
            run_markdown_link_check README.md --config solune/.markdown-link-check.json --quiet 2>&1 | head -10 || true
            FAILED=1
        fi
    fi
fi

# ============================================
# Contract Validation (mirrors CI: Contract Validation)
# ============================================
STAGED_CONTRACT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^solune/backend/src/(api|models)/|^solune/frontend/src/types/)' || true)

if [ -n "$STAGED_CONTRACT_FILES" ]; then
    echo ""
    echo "📋 Contract validation..."

    echo -n "  🔗 OpenAPI schema + type generation... "
    if bash "$REPO_ROOT/solune/scripts/validate-contracts.sh" > /dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
        # Stage regenerated openapi.json and types if they changed
        git add "$REPO_ROOT/solune/backend/openapi.json" 2>/dev/null || true
        git add "$REPO_ROOT/solune/frontend/src/types/openapi-generated.d.ts" 2>/dev/null || true
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Contract validation failed — run: bash solune/scripts/validate-contracts.sh${NC}"
        FAILED=1
    fi
fi

# ============================================
# Architecture Diagram Regeneration
# ============================================
if [ -n "$STAGED_ARCH_FILES" ]; then
    echo ""
    echo "📊 Architecture diagrams..."

    echo -n "  🔄 Regenerating diagrams... "
    diag_err=$(mktemp)
    if "$REPO_ROOT/solune/scripts/generate-diagrams.sh" > /dev/null 2>"$diag_err"; then
        echo -e "${GREEN}✓${NC}"
        # Stage any updated diagram files
        git add "$REPO_ROOT/solune/docs/architectures/" 2>/dev/null || true
    else
        echo -e "${RED}✗${NC}"
        echo -e "${YELLOW}    Diagram generation failed${NC}"
        cat "$diag_err" >&2
        FAILED=1
    fi
    rm -f "$diag_err"
fi

# ============================================
# Pyright pragma gate (Phase 4)
# ============================================
# Stage 1: refuse new `# pyright: basic` inside the strict floor.
# Stage 2: print the global pragma count for SC-006 visibility.
# See solune/specs/001-backend-pyright-strict/contracts/burn-down-gate-contract.md.
if [ -n "$STAGED_BACKEND_CHANGES" ]; then
    floor_violations=$(echo "$STAGED_BACKEND_CHANGES" \
        | grep -E '^solune/backend/src/(api|models|services/agents)/[^/]+(/.*)?\.py$' \
        | xargs -r -I{} grep -lE '^# pyright: basic[[:space:]]*$' "$REPO_ROOT/{}" 2>/dev/null \
        || true)

    if [ -n "$floor_violations" ]; then
        echo ""
        echo -e "${RED}# pyright: basic is not allowed inside the strict floor.${NC}"
        echo "Offending files:"
        printf '  %s\n' $floor_violations
        echo ""
        echo "Remove the pragma and either fix the strict-mode errors or remove"
        echo "the file from the strict floor by amending [tool.pyright] strict."
        FAILED=1
    fi
fi

# Stage 2 — pragma count line (always runs, never affects exit)
pragma_count=$(grep -rEc '^# pyright: basic[[:space:]]*$' "$BACKEND_DIR/src" 2>/dev/null \
                | awk -F: '{s+=$2} END{print s+0}')
echo "# pyright: basic count: $pragma_count"

# ============================================
# Final Result
# ============================================
echo ""
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
    exit 0
else
    echo -e "${RED}❌ Some checks failed. Please fix the remaining issues manually.${NC}"
    exit 1
fi
