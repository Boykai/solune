        },
        {
          "slug": "linter",
          "displayName": "Linter",
          "customAgent": "linter",
          "model": "claude-opus-4.6",
          "instructionTemplate": "solune/scripts/pipelines/templates/linter.md",
          "retryable": true,
          "subIssue": {
            "title": "[Fleet] {{AGENT_DISPLAY_NAME}} for #{{PARENT_ISSUE_NUMBER}} — {{PARENT_ISSUE_TITLE}}",
            "labels": ["ops", "pipeline"]
          }
        }
      ]
    },
    {
      "id": "group-4",
      "name": "DevOps",
      "order": 4,
      "executionMode": "serial",
      "agents": [
        {
          "slug": "devops",
          "displayName": "DevOps",
          "customAgent": "devops",
          "model": "claude-opus-4.6",
          "instructionTemplate": "solune/scripts/pipelines/templates/devops.md",
          "retryable": true,
          "subIssue": {
            "title": "[Fleet] {{AGENT_DISPLAY_NAME}} for #{{PARENT_ISSUE_NUMBER}} — {{PARENT_ISSUE_TITLE}}",
            "labels": ["ops", "pipeline"]
          }
        }
