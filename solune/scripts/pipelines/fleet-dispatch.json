{
  "$schema": "./pipeline-config.schema.json",
  "version": "1",
  "name": "Fleet Dispatch Agent Pipeline",
  "repository": {
    "owner": "Boykai",
    "name": "solune"
  },
  "defaults": {
    "baseRef": "main",
    "errorStrategy": "continue",
    "pollIntervalSeconds": 30,
    "taskTimeoutSeconds": 1800
  },
  "groups": [
    {
      "id": "group-1",
      "name": "Speckit Core",
      "order": 1,
      "executionMode": "serial",
      "agents": [
        {
          "slug": "speckit.specify",
          "displayName": "Spec Kit - Specify",
          "customAgent": "speckit.specify",
          "model": "claude-opus-4.6",
          "instructionTemplate": "solune/scripts/pipelines/templates/speckit.specify.md",
          "retryable": true,
          "subIssue": {
            "title": "[Fleet] {{AGENT_DISPLAY_NAME}} for #{{PARENT_ISSUE_NUMBER}} — {{PARENT_ISSUE_TITLE}}",
            "labels": ["speckit", "pipeline"]
          }
        },
        {
          "slug": "speckit.plan",
          "displayName": "Spec Kit - Plan",
          "customAgent": "speckit.plan",
          "model": "claude-opus-4.6",
          "instructionTemplate": "solune/scripts/pipelines/templates/speckit.plan.md",
          "retryable": true,
          "subIssue": {
            "title": "[Fleet] {{AGENT_DISPLAY_NAME}} for #{{PARENT_ISSUE_NUMBER}} — {{PARENT_ISSUE_TITLE}}",
            "labels": ["speckit", "pipeline"]
          }
        },
        {
          "slug": "speckit.tasks",
          "displayName": "Spec Kit - Tasks",
          "customAgent": "speckit.tasks",
          "model": "claude-opus-4.6",
          "instructionTemplate": "solune/scripts/pipelines/templates/speckit.tasks.md",
          "retryable": true,
          "subIssue": {
            "title": "[Fleet] {{AGENT_DISPLAY_NAME}} for #{{PARENT_ISSUE_NUMBER}} — {{PARENT_ISSUE_TITLE}}",
            "labels": ["speckit", "pipeline"]
          }
        },
        {
          "slug": "speckit.analyze",
          "displayName": "Spec Kit - Analyze",
          "customAgent": "speckit.analyze",
          "model": "claude-opus-4.6",
          "instructionTemplate": "solune/scripts/pipelines/templates/speckit.analyze.md",
          "retryable": true,
          "subIssue": {
            "title": "[Fleet] {{AGENT_DISPLAY_NAME}} for #{{PARENT_ISSUE_NUMBER}} — {{PARENT_ISSUE_TITLE}}",
            "labels": ["speckit", "pipeline"]
          }
        },
        {
          "slug": "speckit.implement",
          "displayName": "Spec Kit - Implement",
          "customAgent": "speckit.implement",
          "model": "claude-opus-4.6",
          "instructionTemplate": "solune/scripts/pipelines/templates/speckit.implement.md",
          "retryable": true,
          "subIssue": {
            "title": "[Fleet] {{AGENT_DISPLAY_NAME}} for #{{PARENT_ISSUE_NUMBER}} — {{PARENT_ISSUE_TITLE}}",
            "labels": ["speckit", "pipeline"]
          }
        }
      ]
    },
    {
      "id": "group-2",
      "name": "Quality Gate",
      "order": 2,
      "executionMode": "parallel",
      "agents": [
        {
          "slug": "quality-assurance",
          "displayName": "Quality Assurance",
          "customAgent": "quality-assurance",
          "model": "claude-opus-4.6",
          "instructionTemplate": "solune/scripts/pipelines/templates/quality-assurance.md",
          "retryable": true,
