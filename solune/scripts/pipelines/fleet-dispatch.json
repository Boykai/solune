          }
        },
        {
          "slug": "copilot-review",
          "displayName": "Copilot Review",
          "customAgent": "copilot-review",
          "model": "claude-opus-4.6",
          "instructionTemplate": "solune/scripts/pipelines/templates/copilot-review.md",
          "retryable": true,
          "subIssue": {
            "title": "[Fleet] {{AGENT_DISPLAY_NAME}} for #{{PARENT_ISSUE_NUMBER}} — {{PARENT_ISSUE_TITLE}}",
            "labels": ["quality", "pipeline"]
          }
        }
      ]
    },
    {
      "id": "group-3",
      "name": "Judgement",
      "order": 3,
      "executionMode": "parallel",
      "agents": [
        {
          "slug": "judge",
          "displayName": "Judge",
