{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solune.dev/contracts/fleet-dispatch-pipeline-config.schema.json",
  "title": "Fleet Dispatch Pipeline Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "repository", "defaults", "groups"],
  "properties": {
    "version": {"type": "string", "const": "1"},
    "name": {"type": "string", "minLength": 1},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "name"],
      "properties": {
        "owner": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1}
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseRef", "errorStrategy", "pollIntervalSeconds", "taskTimeoutSeconds"],
      "properties": {
        "baseRef": {"type": "string", "minLength": 1},
        "errorStrategy": {"type": "string", "enum": ["fail-fast", "continue"]},
        "pollIntervalSeconds": {"type": "integer", "minimum": 5},
        "taskTimeoutSeconds": {"type": "integer", "minimum": 5}
      }
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/group"}
    }
  },
  "$defs": {
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "order", "executionMode", "agents"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "order": {"type": "integer", "minimum": 0},
        "executionMode": {"type": "string", "enum": ["serial", "parallel"]},
        "agents": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/agent"}}
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "customAgent", "model", "instructionTemplate", "subIssue", "retryable"],
      "properties": {
        "slug": {"type": "string", "minLength": 1},
        "displayName": {"type": "string"},
        "customAgent": {"type": "string"},
        "model": {"type": "string", "minLength": 1},
        "instructionTemplate": {"type": "string", "minLength": 1},
        "retryable": {"type": "boolean"},
        "subIssue": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "labels"],
          "properties": {
            "title": {"type": "string", "minLength": 1},
            "labels": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  }
}
